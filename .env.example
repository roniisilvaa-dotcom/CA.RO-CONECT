# ══════════════════════════════════════════════════
# CA.RO CONNECT — Variáveis de Ambiente
# Copie este arquivo para .env.local (nunca commite .env.local)
# ══════════════════════════════════════════════════

# ── BANCO DE DADOS (Neon PostgreSQL) ──────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── IA (Anthropic) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ── WHATSAPP (Meta Cloud API) ─────────────────────
# Obtido em: developers.facebook.com → seu app → WhatsApp → Configuração da API
META_PHONE_NUMBER_ID=xxx           # ID do número de telefone
META_WHATSAPP_TOKEN=EAAxxx         # Token de acesso permanente
META_VERIFY_TOKEN=caro-connect-2024  # Qualquer senha — você define aqui

# ── INSTAGRAM (Meta) ──────────────────────────────
# Mesmo app, mesma página conectada ao Instagram da Camila
META_INSTAGRAM_TOKEN=EAAxxx        # Token com permissão instagram_manage_messages
META_INSTAGRAM_ID=xxx              # ID da conta Instagram Business

# ── APP (interno) ─────────────────────────────────
NEXTAUTH_SECRET=qualquer-string-aleatoria-aqui
NODE_ENV=production
